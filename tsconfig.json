{
	"include": ["**/*.ts", "**/*.tsx"],
	"exclude": [
		"node_modules",
		"my-remix-app",
		"remix",
		"build",
		"server-build",
		"public/build",
		"playwright-report"
	],
	"extends": ["@epic-web/config/typescript"],
	"compilerOptions": {
		"paths": {
			"#app/*": ["./app/*"],
			"#tests/*": ["./tests/*"],
			"@/icon-name": [
				"./app/components/ui/icons/name.d.ts",
				"./types/icon-name.d.ts"
			]
		}
	}
}
